{
  "expo": {
    "name": "AppMobile",
    "slug": "AppMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "appmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Church App",
      "shortName": "ChurchApp",
      "description": "Application de gestion d'église",
      "themeColor": "#0a7ea4",
      "backgroundColor": "#ffffff",
      "orientation": "portrait",
      "lang": "fr",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "barStyle": "default",
      "preferRelatedApplications": false,
      "relatedApplications": [],
      "dangerous": {
        "enableStaticViewport": true
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
